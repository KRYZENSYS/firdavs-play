# ===== Core =====
APP_ENV=production
APP_NAME=Firdavs Play
APP_URL=https://firdavs-play.com
WEBAPP_URL=https://t.me/FirdavsPlayBot/play

# ===== Security =====
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ===== Database =====
POSTGRES_USER=firdavs
POSTGRES_PASSWORD=firdavs_secret
POSTGRES_DB=firdavs_play
DATABASE_URL=postgresql+asyncpg://firdavs:firdavs_secret@postgres:5432/firdavs_play
REDIS_URL=redis://redis:6379/0

# ===== Game economy =====
MIN_BET=10
MAX_BET=100000
DEFAULT_COINS=1000
DAILY_BONUS=100
WEEKLY_BONUS=1000
HOUSE_EDGE=0.04
ANTI_CHEAT_ENABLED=true

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=FirdavsPlayBot
ADMIN_IDS=123456789

# ===== Bot =====
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
BOT_USERNAME=FirdavsPlayBot
API_URL=http://api:8000

# ===== Web =====
NEXT_PUBLIC_API_URL=https://api.firdavs-play.com
NEXT_PUBLIC_BOT_USERNAME=FirdavsPlayBot
