# Replit Secrets — copy values here for local dev
# In Replit, set these in the Secrets tab (lock icon)

# Telegram bot (optional, app works without)
BOT_TOKEN=1234567890:AAH-your-bot-token-from-BotFather
BOT_USERNAME=YourBotUsername

# Public URL of your Replit (for WebApp button)
WEBAPP_URL=https://your-repl-name.repl.co

# Comma-separated admin Telegram IDs
ADMIN_TELEGRAM_IDS=123456789,987654321

# Long random string (dev default works)
JWT_SECRET=change-me-in-production-please-use-a-very-long-secret-key

# SQLite (default works)
DATABASE_URL=sqlite+aiosqlite:///./firdavs.db

# Game tuning
HOUSE_EDGE=0.04
DAILY_BONUS=100
WEEKLY_BONUS=1000
REFERRAL_BONUS=500

# Dev mode
DEV_MODE=true
