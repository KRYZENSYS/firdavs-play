# ===== App =====
APP_NAME=FirdavsPlay
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
WS_URL=ws://localhost:8000

# ===== Database =====
POSTGRES_USER=firdavs
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=firdavs_play
DATABASE_URL=postgresql+asyncpg://firdavs:changeme_postgres@db:5432/firdavs_play

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# ===== JWT =====
JWT_SECRET=replace_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=10080

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=123456:your-bot-token-from-botfather
TELEGRAM_BOT_USERNAME=FirdavsPlayBot
TELEGRAM_WEBAPP_URL=https://t.me/FirdavsPlayBot/play

# ===== Security =====
TELEGRAM_INIT_DATA_SECRET=replace_with_hmac_secret
RATE_LIMIT_PER_MIN=60
ANTI_CHEAT_ENABLED=true
PROVABLY_FAIR_ENABLED=true

# ===== Bot =====
BOT_ADMIN_IDS=123456789
BOT_WEBHOOK_DOMAIN=
BOT_WEBHOOK_PORT=8080
BOT_POLLING=true

# ===== Frontend =====
NEXT_PUBLIC_APP_NAME=Firdavs Play
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=FirdavsPlayBot

# ===== Monitoring =====
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_grafana
SENTRY_DSN=
LOG_LEVEL=INFO

# ===== Game defaults =====
DEFAULT_COINS=1000
DAILY_BONUS=100
WEEKLY_BONUS=1000
MIN_BET=10
MAX_BET=100000
HOUSE_EDGE=0.04
